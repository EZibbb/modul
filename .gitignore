# Graphify — knowledge graph artifacts
# Кеш и manifest нужны для --update; в репо хранить можно, но опционально.
# Чанки и временные файлы — точно не нужны.
.graphify_*
graphify-out/.graphify_*
graphify-out/.needs_update

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# Вендорные скиллы (ui-ux-pro-max / CKM, ставятся через `npx skills add`) — не в git
.agents/

# IDE / OS
.vscode/
.idea/
.obsidian/
.DS_Store
Thumbs.db

# Obsidian community notes (auto-generated by graphify --obsidian)
_COMMUNITY_*.md

# Логи и временные
*.log
*.tmp
*.swp

# Локальные секреты
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key

# TypeScript incremental builds
*.tsbuildinfo
next-env.d.ts

# Coverage / test artifacts
/coverage
/.nyc_output

# Node (если будет)
node_modules/
.next/
dist/
build/

# Скиллы (junction → не нужно коммитить)
.claude/
.gstack/
